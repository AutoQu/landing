---
import { SiteMetadata } from '../config'
import FeaturedImage from '../assets/svg/undraw/undraw_design_inspiration.svg'
---

<div class="relative bg-gradient-to-br from-primary-50 to-secondary-50 dark:from-primary-900/30 dark:to-secondary-900/30">
  <div class='mx-auto max-w-7xl'>
    <div
      class='relative z-10 bg-white pb-8 sm:pb-16 md:pb-20 lg:w-full lg:max-w-2xl lg:pb-28 xl:pb-32 dark:bg-gray-900'
    >
      <svg
        class='absolute inset-y-0 right-0 hidden h-full w-48 translate-x-1/2 transform text-white lg:block dark:text-gray-900'
        fill='currentColor'
        viewBox='0 0 100 100'
        preserveAspectRatio='none'
        aria-hidden='true'
      >
        <polygon points='50,0 100,0 50,100 0,100'></polygon>
      </svg>
      <main
        class='mx-auto max-w-7xl px-4 pt-10 sm:px-6 sm:pt-12 md:pt-16 lg:px-8 lg:pt-20 xl:pt-28'
      >
        <div class='text-center sm:text-left'>
          <h1
            class='text-left text-4xl font-extrabold tracking-tight text-gray-900 sm:text-5xl md:text-6xl dark:text-gray-100'
          >
            <span class='block xl:inline'>{SiteMetadata.title}</span>{' '}
            <span class='block text-primary-700 xl:inline dark:text-primary-300'>{SiteMetadata.org.name}</span>
          </h1>
          <p
            class='mt-3 text-base text-gray-600 sm:mx-auto sm:mt-5 sm:max-w-xl sm:text-lg md:mt-5 md:text-xl lg:mx-0 dark:text-gray-300'
          >
            {SiteMetadata.description}
          </p>
          <p
            class='mt-3 text-base text-gray-600 sm:mx-auto sm:mt-5 sm:max-w-xl sm:text-lg md:mt-5 md:text-xl lg:mx-0 dark:text-gray-300'
          >
            {SiteMetadata.org.summary}
          </p>
          <div class='mt-5 sm:mt-8 sm:flex sm:justify-center lg:justify-start'>
            <div class='rounded-md shadow'>
              <a
                href='/about'
                class='flex w-full items-center justify-center rounded-md border border-transparent bg-primary-600 px-8 py-3 text-base font-medium text-white hover:bg-secondary-600 md:px-10 md:py-4 md:text-lg dark:bg-primary-300 dark:text-black dark:hover:bg-secondary-300'
              >
                Learn More
              </a>
            </div>
            <div class='mt-3 sm:mt-0 sm:ml-3'>
              <a
                href={SiteMetadata.repository}
                class='flex w-full items-center justify-center rounded-md border border-transparent bg-primary-100 px-8 py-3 text-base font-medium text-primary-800 hover:bg-secondary-200 md:px-10 md:py-4 md:text-lg dark:bg-primary-900 dark:text-primary-100 dark:hover:bg-secondary-900'
                rel='noopener noreferrer'
                target='_blank'
              >
                Get Started
              </a>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>
  <div class='bg-primary-100 lg:absolute lg:inset-y-0 lg:right-0 lg:w-1/2 dark:bg-primary-500'>
    <img
      class='h-56 w-full object-contain sm:h-72 md:h-96 lg:h-full lg:w-full'
      src={FeaturedImage.src}
      alt='Featured Image'
    />
  </div>
</div>
